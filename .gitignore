# ---- HiCarta .gitignore ----
# Track source scripts, launchers, config, docs and small sample fixtures.
# Exclude large downloaded caches, generated artifacts and backups.

# Local configuration with private data URLs (copy config.example.txt -> config.txt)
config.txt

# Sample menu that points to collaborators' actual datasets (keep local only)
sample/juicer_sample.txt

# Downloaded .hic / bigWig cache (regenerated on demand, can be hundreds of MB)
_hic_cache/

# Generated / parsed caches
*.genes.rds
*.sqlite
*.sqlite-journal

# Backups (editors, ad-hoc, log-repair tool)
*.bak
*~
*.logrepair_bak_*

# R session artifacts
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# obsidian
.obsidian/
